# Slack Bot
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-api-key

# DAI Supabase (sessions, learnings, memories, etc.)
DAI_SUPABASE_URL=https://your-dai-project.supabase.co
DAI_SUPABASE_SERVICE_KEY=your-dai-service-role-key

# BMAD Supabase (client data, ad performance - optional)
SUPABASE_URL=https://your-bmad-project.supabase.co
SUPABASE_SERVICE_KEY=your-bmad-service-role-key

# Google OAuth (optional — run "pnpm google:setup" to get refresh tokens)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN_WORK=your-work-refresh-token
GOOGLE_REFRESH_TOKEN_PERSONAL=your-personal-refresh-token

# Jasmin dedicated bot (optional — create a separate Slack app for Jasmin DMs)
JASMIN_BOT_TOKEN=xoxb-jasmin-bot-token
JASMIN_APP_TOKEN=xapp-jasmin-app-token

# Ada dedicated bot (optional — create a separate Slack app for Ada)
ADA_BOT_TOKEN=xoxb-ada-bot-token
ADA_APP_TOKEN=xapp-ada-app-token
ADA_DM_ALLOWED_USERS=  # Comma-separated Slack user IDs allowed to DM Ada directly

# Maya dedicated bot (optional — create a separate Slack app for Maya)
MAYA_BOT_TOKEN=xoxb-maya-bot-token
MAYA_APP_TOKEN=xapp-maya-app-token

# App
SLACK_OWNER_USER_ID=U-your-slack-user-id
SLACK_USER_TOKEN=xoxp-your-user-oauth-token
LOG_LEVEL=info
NODE_ENV=development
