{
  "name": "dai",
  "version": "0.1.0",
  "description": "DAI - Daniel's AI: Multi-Agent Slack System",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node --env-file=.env dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "migrate": "tsx scripts/migrate.ts"
  },
  "keywords": [
    "slack",
    "ai",
    "agents",
    "claude"
  ],
  "author": "Daniel Bulygin",
  "license": "MIT",
  "packageManager": "pnpm@10.30.1",
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.50",
    "@anthropic-ai/sdk": "^0.78.0",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.14.1",
    "@supabase/supabase-js": "^2.97.0",
    "better-sqlite3": "^12.6.2",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "nanoid": "^5.1.6",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
