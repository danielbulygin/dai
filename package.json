{
  "name": "dai",
  "version": "0.1.0",
  "description": "DAI - Daniel's AI: Multi-Agent Slack System",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node --env-file=.env dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "migrate": "tsx scripts/migrate.ts",
    "backfill:fireflies": "tsx --env-file=.env scripts/backfill-fireflies.ts",
    "extract:methodology": "tsx --env-file=.env scripts/extract-methodology.ts",
    "extract:kousha": "tsx --env-file=.env scripts/extract-kousha-methodology.ts",
    "google:setup": "tsx --env-file=.env scripts/google-oauth-setup.ts",
    "creative-audit": "tsx --env-file=.env scripts/creative-audit.ts"
  },
  "keywords": [
    "slack",
    "ai",
    "agents",
    "claude"
  ],
  "author": "Daniel Bulygin",
  "license": "MIT",
  "packageManager": "pnpm@10.30.1",
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.50",
    "@anthropic-ai/sdk": "^0.78.0",
    "@hono/node-server": "^1.19.11",
    "@notionhq/client": "^5.9.0",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.14.1",
    "@supabase/supabase-js": "^2.97.0",
    "assemblyai": "^4.23.1",
    "googleapis": "^171.4.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.5",
    "js-yaml": "^4.1.1",
    "nanoid": "^5.1.6",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "playwright-core": "^1.58.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.0",
    "@types/node-cron": "^3.0.11",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
